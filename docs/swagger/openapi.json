{
  "openapi": "3.0.3",
  "info": {
    "title": "La Tanda API",
    "version": "4.11.3",
    "description": "API completa de La Tanda v4.11.3 — Incluye nuevos endpoints de Social Feed, Reverse Payments y Analytics."
  },
  "paths": {
    "/api/feed/social/track-views": {
      "post": {
        "tags": ["Social Feed"],
        "summary": "View tracking (v4.11.3)",
        "responses": { "200": { "description": "OK" } }
      }
    },
    "/api/contributions/{contributionId}/reverse": {
      "post": {
        "tags": ["Contributions"],
        "summary": "Payment reversal (v4.11.2)",
        "parameters": [{ "name": "contributionId", "in": "path", "required": true, "schema": { "type": "string" } }],
        "responses": { "200": { "description": "Reversed" } }
      }
    },
    "/api/groups/{groupId}/contribution-history": {
      "get": {
        "tags": ["Groups"],
        "summary": "Contribution history matrix (v4.11.1)",
        "parameters": [{ "name": "groupId", "in": "path", "required": true, "schema": { "type": "string" } }],
        "responses": { "200": { "description": "Matrix Data" } }
      }
    }
  }
}
